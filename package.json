{
  "name": "quaynt",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source AI visibility platform. Track how your brand appears across AI-powered search and recommendation engines.",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "worker": "tsx src/worker.ts",
    "build:worker": "esbuild src/worker.ts --bundle --platform=node --outfile=dist/worker.cjs --packages=external",
    "test": "vitest",
    "test:run": "vitest run",
    "test:a11y": "playwright test",
    "lint": "eslint --cache --cache-location .next/cache/eslint/ .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xheggs/quaynt.git"
  },
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/xheggs/quaynt/issues"
  },
  "homepage": "https://github.com/xheggs/quaynt#readme",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@paralleldrive/cuid2": "^3.3.0",
    "@react-email/components": "^1.0.11",
    "@react-email/render": "^2.0.5",
    "@react-pdf/renderer": "^4.4.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cronstrue": "^3.14.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "echarts": "^6.0.0",
    "geist": "^1.7.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.4",
    "nuqs": "^2.8.9",
    "pg": "^8.20.0",
    "pg-boss": "^12.15.0",
    "pino": "^10.3.1",
    "postcss": "^8.5.9",
    "radix-ui": "^1.4.3",
    "rate-limiter-flexible": "^10.0.1",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "sentiment": "^5.0.2",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sentiment": "^5.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0"
  }
}
