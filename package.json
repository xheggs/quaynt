{
  "name": "quaynt",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source AI visibility platform. Track how your brand appears across AI-powered search and recommendation engines.",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "worker": "tsx src/worker.ts",
    "build:worker": "esbuild src/worker.ts --bundle --platform=node --outfile=dist/worker.cjs --packages=external",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint --cache --cache-location .next/cache/eslint/ .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xheggs/quaynt.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/xheggs/quaynt/issues"
  },
  "homepage": "https://github.com/xheggs/quaynt#readme",
  "dependencies": {
    "@paralleldrive/cuid2": "^3.3.0",
    "@react-email/components": "^1.0.11",
    "@react-email/render": "^2.0.5",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.2",
    "next-intl": "^4.9.0",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "pg-boss": "^12.15.0",
    "pino": "^10.3.1",
    "rate-limiter-flexible": "^10.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sentiment": "^5.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sentiment": "^5.0.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
