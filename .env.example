# Quaynt — Environment Configuration
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Three usage modes:
#
# 1. Hybrid dev (recommended):
#    Run \`docker compose up\` for PostgreSQL, then \`npm run dev\` on the host.
#    DATABASE_URL uses localhost since the app runs on the host.
#
# 2. Full-Docker dev:
#    Run \`docker compose --profile dev up\`. All env vars are set in
#    compose.yaml — this file is not used in full-Docker mode.
#
# 3. Production:
#    Run \`docker compose -f compose.prod.yaml up -d\`. All values below
#    must be set explicitly. Use strong, unique secrets.

# --- Database ---
# Hybrid dev: localhost (app on host, PostgreSQL in Docker)
# Production: use your database host and strong credentials
DATABASE_URL=postgresql://quaynt:quaynt@localhost:5432/quaynt

# --- Authentication ---
# MUST be at least 32 characters. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# --- Application ---
PORT=3000
NODE_ENV=development
QUAYNT_EDITION=community

# --- PostgreSQL (used by compose.prod.yaml) ---
# These are read by the postgres container in production.
# In hybrid/full-Docker dev, defaults are set in compose.yaml.
POSTGRES_USER=quaynt
POSTGRES_PASSWORD=quaynt
POSTGRES_DB=quaynt

# --- Rate Limiting ---
RATE_LIMIT_POINTS=100           # Max requests per window (default: 100)
RATE_LIMIT_DURATION=60          # Window duration in seconds (default: 60)

# --- CORS ---
CORS_ALLOWED_ORIGINS=*          # Comma-separated origins, or * for all

# --- Logging ---
LOG_LEVEL=info                  # pino log level: trace, debug, info, warn, error, fatal

# --- Webhooks ---
WEBHOOK_TIMEOUT_MS=10000        # HTTP timeout for webhook delivery (ms)
WEBHOOK_MAX_PAYLOAD_SIZE=65536  # Maximum webhook payload size (bytes)

# --- Adapters ---
# Required for encrypting platform adapter credentials. Generate with: openssl rand -hex 32
ADAPTER_ENCRYPTION_KEY=

# --- Alerts ---
ALERT_MAX_RULES_PER_WORKSPACE=25

# --- Email Notifications (disabled by default) ---
# Enable to send alert emails. Supports any SMTP provider
# (Resend, Postmark, Amazon SES, Gmail, self-hosted).
EMAIL_ENABLED=false
EMAIL_FROM="Quaynt <notifications@quaynt.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TLS=false                  # Set true for port 465 (implicit TLS)

# --- Reports ---
REPORT_STORAGE_PATH=./data/reports  # Directory for generated report PDFs

# --- Crawler Analytics ---
CRAWLER_MAX_UPLOAD_SIZE=209715200   # Max upload file size in bytes (default: 200MB)
CRAWLER_VISIT_RETENTION_DAYS=90     # Days to keep raw visit data (default: 90)

# --- AI Traffic Attribution ---
TRAFFIC_COLLECTOR_PUBLIC_URL=https://attribution.quaynt.io  # Public URL the snippet posts to; self-hosters point at their own instance
TRAFFIC_VISIT_RETENTION_DAYS=90                             # Days to keep raw ai_visit rows (aggregates retained indefinitely)

# --- Google Search Console Integration (optional) ---
# Required to enable the GSC correlation feature (/settings/integrations/gsc).
# Provisioning steps:
#   1. Create a Google Cloud project (or reuse one).
#   2. Enable the "Google Search Console API".
#   3. Configure the OAuth consent screen (internal or external).
#   4. Create an OAuth 2.0 Client ID (type: Web application).
#   5. Set the redirect URI to: {your-app-url}/api/v1/integrations/gsc/oauth/callback
#   6. Paste the client ID + secret below; set the redirect URI to match.
# See docs/integrations/google-search-console.md for detailed instructions.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/integrations/gsc/oauth/callback

# -- Query fan-out (simulated fan-out / PRP 6.3b) --
# The provider whose adapter credential the simulator reuses when a request does
# not specify one. Must match a configured adapter for the workspace at runtime.
QUERY_FANOUT_SIMULATION_PROVIDER=openai
# Hard cap on simulated sub-queries returned per call. The model is prompted to
# produce ~12; anything beyond this cap is dropped.
QUERY_FANOUT_SIMULATION_MAX_SUB_QUERIES=20
# Age (days) after which untouched cache rows are pruned by the weekly cleanup
# job. Rows with a positive hit count are retained indefinitely.
QUERY_FANOUT_SIMULATION_CACHE_TTL_DAYS=90
