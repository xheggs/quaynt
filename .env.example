# Quaynt — Environment Configuration
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Three usage modes:
#
# 1. Hybrid dev (recommended):
#    Run \`docker compose up\` for PostgreSQL, then \`npm run dev\` on the host.
#    DATABASE_URL uses localhost since the app runs on the host.
#
# 2. Full-Docker dev:
#    Run \`docker compose --profile dev up\`. All env vars are set in
#    compose.yaml — this file is not used in full-Docker mode.
#
# 3. Production:
#    Run \`docker compose -f compose.prod.yaml up -d\`. All values below
#    must be set explicitly. Use strong, unique secrets.

# --- Database ---
# Hybrid dev: localhost (app on host, PostgreSQL in Docker)
# Production: use your database host and strong credentials
DATABASE_URL=postgresql://quaynt:quaynt@localhost:5432/quaynt

# --- Authentication ---
# MUST be at least 32 characters. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# --- Application ---
PORT=3000
NODE_ENV=development
QUAYNT_EDITION=community

# --- PostgreSQL (used by compose.prod.yaml) ---
# These are read by the postgres container in production.
# In hybrid/full-Docker dev, defaults are set in compose.yaml.
POSTGRES_USER=quaynt
POSTGRES_PASSWORD=quaynt
POSTGRES_DB=quaynt

# --- Rate Limiting ---
RATE_LIMIT_POINTS=100           # Max requests per window (default: 100)
RATE_LIMIT_DURATION=60          # Window duration in seconds (default: 60)

# --- CORS ---
CORS_ALLOWED_ORIGINS=*          # Comma-separated origins, or * for all

# --- Logging ---
LOG_LEVEL=info                  # pino log level: trace, debug, info, warn, error, fatal

# --- Webhooks ---
WEBHOOK_TIMEOUT_MS=10000        # HTTP timeout for webhook delivery (ms)
WEBHOOK_MAX_PAYLOAD_SIZE=65536  # Maximum webhook payload size (bytes)

# --- Adapters ---
# Required for encrypting platform adapter credentials. Generate with: openssl rand -hex 32
ADAPTER_ENCRYPTION_KEY=

# --- Alerts ---
ALERT_MAX_RULES_PER_WORKSPACE=25

# --- Email Notifications (disabled by default) ---
# Enable to send alert emails. Supports any SMTP provider
# (Resend, Postmark, Amazon SES, Gmail, self-hosted).
EMAIL_ENABLED=false
EMAIL_FROM="Quaynt <notifications@quaynt.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TLS=false                  # Set true for port 465 (implicit TLS)
